# -----------------------------------------------------------------------------
# .env.example — 环境变量模板（提交 Git；Next 不会加载此文件）
# -----------------------------------------------------------------------------
# 使用：在 slack-frontend 目录执行
#   cp .env.example .env.local
# 然后编辑 .env.local。.env.local 已被 git 忽略，勿提交密钥。
# -----------------------------------------------------------------------------

# --- 站点 ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- 数据库（在 slack-frontend 目录执行 pnpm db:up）---
DATABASE_URL=postgresql://moyu:moyu_dev@localhost:5432/moyuai

# --- Auth.js（Phase 1）---
# 生成 secret：openssl rand -base64 32
AUTH_SECRET=
# 必须与浏览器访问地址一致（含协议、端口，无尾部斜杠）
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
# 本地用 QQ 等网页邮箱测试 magic link 时，localhost 链接常被安全检测拦截无法跳转。
# 请用 ngrok 等隧道暴露本地服务，并将上述 URL 与 NEXT_PUBLIC_APP_URL 改为公网地址。

# GitHub OAuth — 在 https://github.com/settings/developers 创建 OAuth App
# Homepage URL: 与 NEXTAUTH_URL 一致（如 https://dev.moyuai.cc）
# Authorization callback URL: {NEXTAUTH_URL}/api/auth/callback/github
# 示例：https://dev.moyuai.cc/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth（可选）
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# 邮箱 magic link
# - 未配置：开发模式，magic link 打印在 pnpm dev 终端
# - 163 推荐分项配置（避免授权码 URL 编码问题）：
#     EMAIL_SMTP_HOST=smtp.163.com
#     EMAIL_SMTP_PORT=465
#     EMAIL_SMTP_SECURE=true
#     EMAIL_SMTP_USER=limin_chu@163.com
#     EMAIL_SMTP_PASS=163授权码（不是登录密码）
#     EMAIL_FROM=摸鱼AI <limin_chu@163.com>
# - 或单行：EMAIL_SERVER=smtps://limin_chu@163.com:授权码@smtp.163.com:465
# - 密钥写在 .env.local，勿提交 Git
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=465
EMAIL_SMTP_SECURE=true
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_SERVER=
EMAIL_FROM=摸鱼AI <your-name@163.com>
NEXT_PUBLIC_AUTH_EMAIL_DEV=true

# --- 协同 / 转换（后续 Phase 使用）---
NEXT_PUBLIC_WS_URL=ws://localhost:3001
CONVERTER_URL=http://localhost:3002

# --- 日志 ---
LOG_LEVEL=info

# 开发服务器额外允许的 Origin（逗号分隔）
# ALLOWED_DEV_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
